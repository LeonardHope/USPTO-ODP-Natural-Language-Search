# USPTO Open Data Portal Search — API Key Configuration
#
# QUICKEST SETUP: Run the interactive setup script:
#   python get_started.py
#
# MANUAL OPTION: Copy this file to .env and fill in your key:
#   cp .env.example .env
#
# ALTERNATIVE: Set as an environment variable in your shell profile (~/.zshrc or ~/.bashrc):
#   export USPTO_ODP_API_KEY="your_key_here"
#
# NEVER commit your actual API key to version control.

# USPTO Open Data Portal API Key (required)
# Get yours free at: https://data.uspto.gov/myodp
# Covers all APIs: Patent File Wrapper, PTAB, Petitions, Office Actions,
# Bulk Data, TSDR (Trademark Status & Document Retrieval)
USPTO_ODP_API_KEY=
