# USPTO Patent Search Skill - API Key Configuration
#
# QUICKEST SETUP: Run the interactive setup script:
#   python get_started.py
#
# MANUAL OPTION: Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# ALTERNATIVE: Set as environment variables in your shell profile (~/.zshrc or ~/.bashrc):
#   export USPTO_ODP_API_KEY="your_key_here"
#   export PATENTSVIEW_API_KEY="your_key_here"
#
# NEVER commit your actual API keys to version control.

# USPTO Open Data Portal API Key
# Get yours free at: https://data.uspto.gov/myodp
USPTO_ODP_API_KEY=

# PatentsView PatentSearch API Key (OPTIONAL)
# Enables CPC/attorney search and citation networks. Without it, searches fall back to ODP.
# Try: https://patentsview-support.atlassian.net/servicedesk/customer/portal/1/group/1/create/18
# Note: PatentsView is migrating to the Open Data Portal on March 20, 2026.
PATENTSVIEW_API_KEY=
